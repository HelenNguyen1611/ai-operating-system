# apps/mcp-gateway — Jira Cloud configuration (Phase 2)
#
# Copy this file to .env and fill in real values, OR export these as real
# shell/process environment variables. This file is never read automatically
# by the gateway — there is no built-in .env loader (deliberate Phase 2
# decision, see ARCHITECTURE.md and ROADMAP.md Phase 2). To actually load a
# .env file at runtime, launch with Node's native flag, e.g.:
#
#   node --env-file=.env dist/index.js
#   npx tsx --env-file=.env src/index.ts
#
# .env itself is git-ignored by the repository root .gitignore (`.env`,
# `.env.*`, with `.env.example` explicitly allowed). Never commit real
# credentials — this file must only ever contain placeholders.

# Your Jira Cloud site base URL, no trailing slash.
# Example: https://your-domain.atlassian.net
JIRA_BASE_URL=https://your-domain.atlassian.net

# The Atlassian account email address associated with the API token below.
JIRA_EMAIL=you@example.com

# A Jira Cloud API token (NOT your account password).
# Create one at: https://id.atlassian.com/manage-profile/security/api-tokens
# This token is used for read-only requests only — the gateway's Jira
# adapter has no write/transition/comment capability (see ARCHITECTURE.md
# and runtime/50_Remote_Gateway.md, Phase 2 Safety section).
JIRA_API_TOKEN=your-api-token-here

# Optional. How many days back jira_get_morning_context's JQL looks
# (assignee = currentUser() AND updated >= -{N}d ORDER BY updated DESC).
# Must be a positive integer, capped at 365. Any missing, non-numeric,
# decimal, zero, negative, or greater-than-365 value falls back to 30 —
# the gateway never fails to start or crashes a call over this value.
# MORNING_CONTEXT_LOOKBACK_DAYS=30

# --- Team Availability (Microsoft Graph, app-only) ---
#
# Reads approved leave/availability rows from the Excel workbook that
# Power Automate updates after approval (the workbook, not Microsoft
# Forms, is the source of truth). Auth is a Graph app-only client
# credentials grant against an Azure AD app registration — there is no
# interactive user in this flow, so it requires an application (not
# delegated) Graph permission such as Files.Read.All, granted with admin
# consent, scoped to the drive containing the workbook.
#
# All five variables below are required together — if any is missing the
# tool returns ADAPTER_NOT_CONFIGURED rather than failing to start.

# Azure AD tenant ID (GUID) the app registration belongs to.
TEAM_AVAILABILITY_TENANT_ID=00000000-0000-0000-0000-000000000000

# Azure AD app registration's client (application) ID.
TEAM_AVAILABILITY_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Azure AD app registration's client secret value (NOT the secret ID).
TEAM_AVAILABILITY_CLIENT_SECRET=your-client-secret-here

# Microsoft Graph driveId of the OneDrive/SharePoint drive holding the
# workbook (WOO GROUP - LEAVE FORM Updated Ver.xlsx). Resolve via Graph
# Explorer, e.g. GET /users/{owner}/drive or GET /sites/{site}/drive.
TEAM_AVAILABILITY_DRIVE_ID=your-drive-id-here

# Microsoft Graph itemId of the workbook file within that drive.
TEAM_AVAILABILITY_ITEM_ID=your-item-id-here

# Optional. Excel table name (Graph object name), not the worksheet name.
# Defaults to "OfficeForms.Table" (the Microsoft Forms-generated table).
# TEAM_AVAILABILITY_TABLE_NAME=OfficeForms.Table
