# apps/mcp-gateway — Jira Cloud configuration (Phase 2)
#
# Copy this file to .env and fill in real values, OR export these as real
# shell/process environment variables. This file is never read automatically
# by the gateway — there is no built-in .env loader (deliberate Phase 2
# decision, see ARCHITECTURE.md and ROADMAP.md Phase 2). To actually load a
# .env file at runtime, launch with Node's native flag, e.g.:
#
#   node --env-file=.env dist/index.js
#   npx tsx --env-file=.env src/index.ts
#
# .env itself is git-ignored by the repository root .gitignore (`.env`,
# `.env.*`, with `.env.example` explicitly allowed). Never commit real
# credentials — this file must only ever contain placeholders.

# Your Jira Cloud site base URL, no trailing slash.
# Example: https://your-domain.atlassian.net
JIRA_BASE_URL=https://your-domain.atlassian.net

# The Atlassian account email address associated with the API token below.
JIRA_EMAIL=you@example.com

# A Jira Cloud API token (NOT your account password).
# Create one at: https://id.atlassian.com/manage-profile/security/api-tokens
# This token is used for read-only requests only — the gateway's Jira
# adapter has no write/transition/comment capability (see ARCHITECTURE.md
# and runtime/50_Remote_Gateway.md, Phase 2 Safety section).
JIRA_API_TOKEN=your-api-token-here

# Optional. How many days back jira_get_morning_context's JQL looks
# (assignee = currentUser() AND updated >= -{N}d ORDER BY updated DESC).
# Must be a positive integer, capped at 365. Any missing, non-numeric,
# decimal, zero, negative, or greater-than-365 value falls back to 30 —
# the gateway never fails to start or crashes a call over this value.
# MORNING_CONTEXT_LOOKBACK_DAYS=30

# --- Team Availability (local Power Automate JSON snapshot) ---
#
# Power Automate reads the approved-leave Excel table and writes a
# cleaned, privacy-safe JSON snapshot into a OneDrive-synced local folder.
# This gateway only ever reads that local file — it never talks to
# Microsoft Graph, Excel, or Microsoft Forms directly. The snapshot must
# not include Reason, uploaded documents, Note, or approver details; the
# adapter's Zod schema strips any unrecognized field as a second,
# independent safeguard, but Power Automate's own filtering is the
# primary privacy control, not this schema.

# Absolute path to the JSON snapshot file (the locally synced OneDrive
# path Power Automate writes to). Required — if unset, the tool returns
# ADAPTER_NOT_CONFIGURED rather than failing to start.
TEAM_AVAILABILITY_SNAPSHOT_PATH=/absolute/path/to/team-availability.json

# Optional. Maximum age, in minutes, of the snapshot's generated_at
# timestamp before the tool refuses to serve it (SNAPSHOT_STALE). Must be
# a positive integer. Unset or blank disables staleness checking
# entirely. Present but invalid (non-numeric, decimal, zero, negative) is
# NOT silently ignored — the tool returns ADAPTER_CONFIG_INVALID instead,
# naming this variable, rather than quietly serving a possibly-stale file.
TEAM_AVAILABILITY_MAX_AGE_MINUTES=120
